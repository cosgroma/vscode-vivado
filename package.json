{
  "name": "vscode-vivado",
  "displayName": "VS Code Vivado",
  "description": "Vivado and Vitis project support for VS Code",
  "version": "0.2.3",
  "icon": "resources/logo.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Debuggers",
    "Testing",
    "Other"
  ],
  "keywords": [
    "xilinx",
    "embedded",
    "fpga",
    "simulation",
    "synthesis",
    "cosimulation",
    "rtl",
    "vivado",
    "amd"
  ],
  "author": {
    "name": "Mathew Cosgrove",
    "email": "cosgroma@gmail.com"
  },
  "publisher": "cosgroma",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cosgroma/vscode-vivado.git"
  },
  "bugs": {
    "url": "https://github.com/cosgroma/vscode-vivado/issues"
  },
  "homepage": "https://github.com/cosgroma/vscode-vivado#readme",
  "activationEvents": [
    "onView:projectsView",
    "workspaceContains:**/hls.app"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "VS Code Vivado",
      "properties": {
        "vitis-hls-ide.vitisPath": {
          "type": "string",
          "default": "C:\\Xilinx\\Vitis\\2023.2",
          "description": "Path to the Vitis installation directory"
        },
        "vitis-hls-ide.hlsPath": {
          "type": "string",
          "default": "C:\\Xilinx\\Vitis_HLS\\2023.2",
          "description": "Path to the Vitis HLS installation directory"
        }
      }
    },
    "commands": [
      {
        "command": "vitis-hls-ide.projects.refresh",
        "title": "VS Code Vivado: Refresh Projects",
        "icon": "$(refresh)"
      },
      {
        "command": "vitis-hls-ide.projects.source.addFiles",
        "title": "Add source files",
        "icon": "$(file-add)"
      },
      {
        "command": "vitis-hls-ide.projects.source.removeFile",
        "title": "Remove source file",
        "icon": "$(remove)"
      },
      {
        "command": "vitis-hls-ide.projects.testbench.addFiles",
        "title": "Add test bench files",
        "icon": "$(file-add)"
      },
      {
        "command": "vitis-hls-ide.projects.testbench.removeFile",
        "title": "Remove test bench file",
        "icon": "$(remove)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vitisHlsIdeMainContainer",
          "title": "VS Code Vivado",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "views": {
      "vitisHlsIdeMainContainer": [
        {
          "id": "projectsView",
          "name": "Projects"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "vitis-hls-ide.projects.refresh",
          "when": "false"
        },
        {
          "command": "vitis-hls-ide.projects.source.addFiles",
          "when": "false"
        },
        {
          "command": "vitis-hls-ide.projects.source.removeFile",
          "when": "false"
        },
        {
          "command": "vitis-hls-ide.projects.testbench.addFiles",
          "when": "false"
        },
        {
          "command": "vitis-hls-ide.projects.testbench.removeFile",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "vitis-hls-ide.projects.refresh",
          "when": "view == projectsView",
          "group": "navigation@0"
        }
      ],
      "view/item/context": [
        {
          "command": "vitis-hls-ide.projects.source.addFiles",
          "when": "view == projectsView && viewItem == projectSourceItem",
          "group": "inline"
        },
        {
          "command": "vitis-hls-ide.projects.source.removeFile",
          "when": "view == projectsView && viewItem == projectSourceFileItem",
          "group": "inline"
        },
        {
          "command": "vitis-hls-ide.projects.testbench.addFiles",
          "when": "view == projectsView && viewItem == projectTestBenchItem",
          "group": "inline"
        },
        {
          "command": "vitis-hls-ide.projects.testbench.removeFile",
          "when": "view == projectsView && viewItem == projectTestBenchFileItem",
          "group": "inline"
        }
      ]
    },
    "problemMatchers": [
      {
        "name": "vitis-hls-ide-csim",
        "owner": "vitis-hls-ide",
        "fileLocation": "absolute",
        "pattern": [
          {
            "regexp": "^([^:]*:[^:]*):(\\d+):((\\d+):)? ((warning|error|note): )?(.*)",
            "file": 1,
            "line": 2,
            "column": 4,
            "severity": 6,
            "message": 7
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "mock:workspace": "node scripts/create-mock-workspace.mjs",
    "docs:build": "python -m mkdocs build --strict",
    "docs:serve": "python -m mkdocs serve"
  },
  "extensionDependencies": [
    "ms-vscode.cpptools"
  ],
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.6",
    "@types/node": "25.x",
    "@types/vscode": "^1.116.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "lodash": "^4.18.1",
    "xml2js": "^0.6.2"
  }
}
