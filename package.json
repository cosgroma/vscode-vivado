{
  "name": "vscode-vivado",
  "displayName": "VS Code Vivado",
  "description": "Vivado and Vitis project support for VS Code",
  "version": "0.2.3",
  "icon": "resources/logo.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Debuggers",
    "Testing",
    "Other"
  ],
  "keywords": [
    "xilinx",
    "embedded",
    "fpga",
    "simulation",
    "synthesis",
    "cosimulation",
    "rtl",
    "vivado",
    "amd"
  ],
  "author": {
    "name": "Mathew Cosgrove",
    "email": "cosgroma@gmail.com"
  },
  "publisher": "cosgroma",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cosgroma/vscode-vivado.git"
  },
  "bugs": {
    "url": "https://github.com/cosgroma/vscode-vivado/issues"
  },
  "homepage": "https://github.com/cosgroma/vscode-vivado#readme",
  "activationEvents": [
    "onView:projectsView",
    "workspaceContains:**/hls.app",
    "workspaceContains:**/*.xpr"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "VS Code Vivado",
      "properties": {
        "vitis-hls-ide.vitisPath": {
          "type": "string",
          "default": "C:\\Xilinx\\Vitis\\2023.2",
          "description": "Path to the Vitis installation directory"
        },
        "vitis-hls-ide.hlsPath": {
          "type": "string",
          "default": "C:\\Xilinx\\Vitis_HLS\\2023.2",
          "description": "Path to the Vitis HLS installation directory"
        },
        "vscode-vivado.vivadoPath": {
          "type": "string",
          "default": "C:\\Xilinx\\Vivado\\2023.2",
          "description": "Path to the Vivado installation directory. When vscode-vivado.vivadoExecutablePath is empty, the extension resolves the Vivado executable from this path."
        },
        "vscode-vivado.vivadoExecutablePath": {
          "type": "string",
          "default": "",
          "description": "Optional full path to the Vivado executable, or a command name available on PATH. Leave empty to resolve from vscode-vivado.vivadoPath."
        },
        "vscode-vivado.vivadoSettingsScript": {
          "type": "string",
          "default": "",
          "description": "Optional path to a Vivado environment setup script such as settings64.bat or settings64.sh."
        },
        "vscode-vivado.projectSearchGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.xpr"
          ],
          "description": "Workspace globs used to discover Vivado projects."
        },
        "vscode-vivado.reportsDirectory": {
          "type": "string",
          "default": "reports",
          "description": "Workspace-relative directory used for Vivado report artifacts when commands need an explicit report output location."
        },
        "vscode-vivado.generatedTclDirectory": {
          "type": "string",
          "default": ".vscode-vivado/tcl",
          "description": "Workspace-relative directory used for generated Vivado TCL scripts. Absolute paths are also supported."
        },
        "vscode-vivado.preserveRunLogs": {
          "type": "boolean",
          "default": true,
          "description": "Keep Vivado task logs after synthesis, implementation, bitstream, and simulation tasks complete."
        }
      }
    },
    "commands": [
      {
        "command": "vitis-hls-ide.projects.refresh",
        "title": "VS Code Vivado: Refresh Projects",
        "icon": "$(refresh)"
      },
      {
        "command": "vitis-hls-ide.projects.source.addFiles",
        "title": "Add source files",
        "icon": "$(file-add)"
      },
      {
        "command": "vitis-hls-ide.projects.source.removeFile",
        "title": "Remove source file",
        "icon": "$(remove)"
      },
      {
        "command": "vitis-hls-ide.projects.testbench.addFiles",
        "title": "Add test bench files",
        "icon": "$(file-add)"
      },
      {
        "command": "vitis-hls-ide.projects.testbench.removeFile",
        "title": "Remove test bench file",
        "icon": "$(remove)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vitisHlsIdeMainContainer",
          "title": "VS Code Vivado",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "views": {
      "vitisHlsIdeMainContainer": [
        {
          "id": "projectsView",
          "name": "Projects"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "vitis-hls-ide.projects.refresh",
          "when": "false"
        },
        {
          "command": "vitis-hls-ide.projects.source.addFiles",
          "when": "false"
        },
        {
          "command": "vitis-hls-ide.projects.source.removeFile",
          "when": "false"
        },
        {
          "command": "vitis-hls-ide.projects.testbench.addFiles",
          "when": "false"
        },
        {
          "command": "vitis-hls-ide.projects.testbench.removeFile",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "vitis-hls-ide.projects.refresh",
          "when": "view == projectsView",
          "group": "navigation@0"
        }
      ],
      "view/item/context": [
        {
          "command": "vitis-hls-ide.projects.source.addFiles",
          "when": "view == projectsView && viewItem == projectSourceItem",
          "group": "inline"
        },
        {
          "command": "vitis-hls-ide.projects.source.removeFile",
          "when": "view == projectsView && viewItem == projectSourceFileItem",
          "group": "inline"
        },
        {
          "command": "vitis-hls-ide.projects.testbench.addFiles",
          "when": "view == projectsView && viewItem == projectTestBenchItem",
          "group": "inline"
        },
        {
          "command": "vitis-hls-ide.projects.testbench.removeFile",
          "when": "view == projectsView && viewItem == projectTestBenchFileItem",
          "group": "inline"
        }
      ]
    },
    "problemMatchers": [
      {
        "name": "vitis-hls-ide-csim",
        "owner": "vitis-hls-ide",
        "fileLocation": "absolute",
        "pattern": [
          {
            "regexp": "^([^:]*:[^:]*):(\\d+):((\\d+):)? ((warning|error|note): )?(.*)",
            "file": 1,
            "line": 2,
            "column": 4,
            "severity": 6,
            "message": 7
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "mock:workspace": "node scripts/create-mock-workspace.mjs",
    "docs:build": "python -m mkdocs build --strict",
    "docs:serve": "python -m mkdocs serve"
  },
  "extensionDependencies": [
    "ms-vscode.cpptools"
  ],
  "devDependencies": {
    "@types/lodash": "^4.17.6",
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "xml2js": "^0.6.2"
  }
}
